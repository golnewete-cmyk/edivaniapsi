<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edivania Soares • Agendamento de Sessões</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        /* RESET E BASE */
        *{margin:0;padding:0;box-sizing:border-box;}
        body{
            font-family:'Inter',sans-serif;
            color:#2a2a2a;
            min-height:100vh;
            overflow-x:hidden;
            background: radial-gradient(circle at 15% 20%, rgba(255,235,240,0.9), transparent 40%),
                        radial-gradient(circle at 85% 30%, rgba(245,240,255,0.9), transparent 40%),
                        radial-gradient(circle at 50% 90%, rgba(255,250,240,0.9), transparent 40%),
                        linear-gradient(120deg,#ffffff,#fdfaf7);
        }
        body::after{
            content:''; position:fixed; top:0; left:0; width:100%; height:100%;
            background:url('https://www.transparenttextures.com/patterns/noise.png');
            opacity:0.03; pointer-events:none;
        }

        /* ANIMAÇÕES DE FUNDO */
        .glow, .glow2{ position:fixed; width:500px; height:500px; filter:blur(120px); z-index: -1; animation:float 10s infinite ease-in-out; }
        .glow{ background:radial-gradient(circle, rgba(255,200,210,0.25), transparent); top:-100px; left:-100px; }
        .glow2{ background:radial-gradient(circle, rgba(200,210,255,0.25), transparent); bottom:-100px; right:-100px; animation-duration: 12s; }
        @keyframes float{ 0%,100%{transform:translateY(0);} 50%{transform:translateY(40px);} }

        /* ESTRUTURA */
        .wrapper{ max-width:720px; margin:auto; padding:80px 25px; }
        h1{ font-family:'Playfair Display',serif; font-size:38px; font-weight:600; text-align:center; margin-bottom:10px; }
        .subtitle{ text-align:center; color:#7a7a7a; margin-bottom:40px; font-size: 15px; }
        
        /* FORMULÁRIO */
        .form{ display:flex; flex-direction:column; gap:20px; }
        .section-title { font-family:'Playfair Display',serif; font-size: 18px; margin-top: 10px; color: #444; border-bottom: 1px solid rgba(0,0,0,0.05); padding-bottom: 5px; }
        
        .row { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        
        .group { display: flex; flex-direction: column; gap: 5px; }
        label { font-size: 12px; color: #888; margin-left: 5px; }

        .input{
            padding:16px; border-radius:14px; border:1px solid rgba(0,0,0,0.08);
            background:rgba(255,255,255,0.9); font-size:14px; font-family:'Inter',sans-serif;
            transition:0.3s;
        }
        .input:focus{ outline:none; border-color:#000; box-shadow:0 8px 20px rgba(0,0,0,0.05); transform:translateY(-1px); }

        /* BOTÃO */
        .btn{
            margin-top:20px; padding:20px; border:none; border-radius:16px;
            font-size:16px; font-weight:600; cursor:pointer;
            background:linear-gradient(135deg,#000,#1c1c1c); color:#fff;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2); transition:0.35s;
        }
        .btn:hover{ transform:translateY(-3px); box-shadow: 0 20px 45px rgba(0,0,0,0.3); }

        .footer{ text-align:center; margin-top:40px; color:#aaa; font-size:11px; letter-spacing: 1px; }
    </style>
</head>
<body>

<div class="glow"></div>
<div class="glow2"></div>

<div class="wrapper">
    <h1>Agendamento</h1>
    <div class="subtitle">Organização das sessões e dados de pagamento</div>

    <form class="form" action="https://docs.google.com/forms/d/e/1FAIpQLScSIFETtzU8_Mm_EvUsjlftmLZd4SZl9tpbkStt34mZide1qw/formResponse" method="POST">
        
        <input class="input" name="entry.528648543" placeholder="Nome do paciente" required>
        <input class="input" name="entry.1286524247" type="email" placeholder="Email do paciente" required>
        
        <div class="row">
            <input class="input" name="entry.92360596" placeholder="Valor do pacote (ex: 500,00)" required>
            <input class="input" name="entry.825364612" placeholder="Sua Chave Pix" required>
        </div>

        <input class="input" name="entry.588676876" placeholder="Link da sala de atendimento (Google Meet/Zoom)" required>

        <div class="section-title">Primeira Sessão</div>
        <div class="row">
            <div class="group">
                <label>Data</label>
                <input class="input" type="date" id="data1" required>
            </div>
            <div class="group">
                <label>Horário</label>
                <input class="input" type="time" id="hora1" required>
            </div>
        </div>

        <div class="section-title">Segunda Sessão</div>
        <div class="row">
            <div class="group">
                <label>Data</label>
                <input class="input" type="date" id="data2">
            </div>
            <div class="group">
                <label>Horário</label>
                <input class="input" type="time" id="hora2">
            </div>
        </div>

        <div class="section-title">Terceira Sessão</div>
        <div class="row">
            <div class="group">
                <label>Data</label>
                <input class="input" type="date" id="data3">
            </div>
            <div class="group">
                <label>Horário</label>
                <input class="input" type="time" id="hora3">
            </div>
        </div>

        <div class="section-title">Vencimento do Pagamento</div>
        <div class="group">
            <input class="input" type="date" id="vencimento" required>
        </div>

        <input type="hidden" name="entry.1908783304_year" id="s1_y">
        <input type="hidden" name="entry.1908783304_month" id="s1_m">
        <input type="hidden" name="entry.1908783304_day" id="s1_d">
        <input type="hidden" name="entry.1823333484_hour" id="s1_h">
        <input type="hidden" name="entry.1823333484_minute" id="s1_min">
        <input type="hidden" name="entry.1354578031_year" id="s2_y">
        <input type="hidden" name="entry.1354578031_month" id="s2_m">
        <input type="hidden" name="entry.1354578031_day" id="s2_d">
        <input type="hidden" name="entry.260210315_hour" id="s2_h">
        <input type="hidden" name="entry.260210315_minute" id="s2_min">
        <input type="hidden" name="entry.1562167682_year" id="s3_y">
        <input type="hidden" name="entry.1562167682_month" id="s3_m">
        <input type="hidden" name="entry.1562167682_day" id="s3_d">
        <input type="hidden" name="entry.136865789_hour" id="s3_h">
        <input type="hidden" name="entry.136865789_minute" id="s3_min">
        <input type="hidden" name="entry.1881702609_year" id="v_y">
        <input type="hidden" name="entry.1881702609_month" id="v_m">
        <input type="hidden" name="entry.1881702609_day" id="v_d">

        <button type="submit" class="btn">Finalizar e Agendar Pacote</button>
    </form>

    <div class="footer">EDIVANIA SOARES • PSICANALISTA</div>
</div>

<script>
    // Script para quebrar as datas/horas nos formatos que o Google Forms aceita antes de enviar
    document.querySelector('form').addEventListener('submit', function() {
        function fillDate(idInput, prefix) {
            val = document.getElementById(idInput).value;
            if(val){
                d = val.split('-');
                document.getElementById(prefix+'_y').value = d[0];
                document.getElementById(prefix+'_m').value = d[1];
                document.getElementById(prefix+'_d').value = d[2];
            }
        }
        function fillTime(idInput, prefix) {
            val = document.getElementById(idInput).value;
            if(val){
                t = val.split(':');
                document.getElementById(prefix+'_h').value = t[0];
                document.getElementById(prefix+'_min').value = t[1];
            }
        }

        fillDate('data1', 's1'); fillTime('hora1', 's1');
        fillDate('data2', 's2'); fillTime('hora2', 's2');
        fillDate('data3', 's3'); fillTime('hora3', 's3');
        fillDate('vencimento', 'v');
    });
</script>

</body>
</html>
